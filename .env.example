# Public site URL (used by metadata, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-string
# Comma-separated list of additional trusted origins
# BETTER_AUTH_TRUSTED_ORIGINS=https://staging.example.com

# Database
# Leave DATABASE_URL empty to use the local SQLite file (sqlite.db).
# Set it to a Neon/Postgres connection string for production/Vercel.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Pakasir payment gateway (optional in demo)
# PAKASIR_PROJECT_SLUG=
# PAKASIR_API_KEY=

# Demo mode
# When DEMO_MODE=1, every mutation (booking, review, admin write,
# sign-up, payment webhook) is rejected with a friendly read-only
# response. Use NEXT_PUBLIC_DEMO_MODE for the public banner and
# the credential autofill on the login page.
DEMO_MODE=0
NEXT_PUBLIC_DEMO_MODE=0
