# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
sqlite.db-shm
sqlite.db-wal

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local

# allow example/template env files to be committed
!.env.example
!.env.vercel.demo
!.env.vercel.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
